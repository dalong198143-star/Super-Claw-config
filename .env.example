# ============================================================
# AI漫剧创作平台 - 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# 服务器配置
PORT=3001
NODE_ENV=development

# Replicate API（注册获取: https://replicate.com）
REPLICATE_API_TOKEN=your_token_here

# 硅基流动 API（注册获取: https://siliconflow.cn）
SILICONFLOW_API_KEY=your_key_here
SILICONFLOW_TEXT2IMG_MODEL=Qwen/Qwen-Image
SILICONFLOW_IMG2VIDEO_MODEL=Wan-AI/Wan2.2-I2V-A14B

# DeepSeek AI（注册获取: https://platform.deepseek.com）
DEEPSEEK_API_KEY=your_key_here
DEEPSEEK_MODEL=deepseek-chat

# TTS 配音服务（可选）
# AZURE_TTS_KEY=your_key_here
# AZURE_TTS_REGION=eastus
# ELEVENLABS_API_KEY=your_key_here

# CORS 允许的源（多个用逗号分隔）
# 开发环境
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
# 生产环境（Docker）
# ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
